# ══════════════════════════════════════════════════════════════════════════════
# Rally Configuration
# ══════════════════════════════════════════════════════════════════════════════
NODE_ENV=production

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-this-to-a-strong-password
DATABASE_URL=postgresql://rally:change-this-to-a-strong-password@postgres:5432/rally

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=generate-a-random-64-char-string-here
JWT_REFRESH_SECRET=generate-another-random-64-char-string-here

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=https://yourdomain.com

# ── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=104857600

# ── WebRTC (Mediasoup) ──────────────────────────────────────────────────────
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=your-server-public-ip

# ── Domain (for SSL) ────────────────────────────────────────────────────────
DOMAIN=yourdomain.com
PUBLIC_IP=your-server-public-ip

# ── Email (optional, for password reset) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
