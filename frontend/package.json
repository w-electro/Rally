{
  "name": "rally",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "author": {
    "name": "Rally Team",
    "email": "team@rally.dev"
  },
  "homepage": "https://rally.dev",
  "description": "Rally — Voice, Video & Text for Gamers",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "vite & sleep 3 && electron .",
    "electron:build": "tsc -b && vite build && electron-builder --config electron-builder.json",
    "dist:linux": "tsc -b && vite build && electron-builder --linux --config electron-builder.json",
    "dist:win": "tsc -b && vite build && electron-builder --win --config electron-builder.json",
    "dist:mac": "tsc -b && vite build && electron-builder --mac --config electron-builder.json"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.1.2",
    "@emoji-mart/react": "^1.1.1",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "emoji-mart": "^5.5.2",
    "lucide-react": "^0.344.0",
    "mediasoup-client": "^3.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "react-hot-toast": "^2.4.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.22.0",
    "react-syntax-highlighter": "^15.5.0",
    "socket.io-client": "^4.7.4",
    "tailwind-merge": "^2.2.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/react-syntax-highlighter": "^15.5.11",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^40.3.0",
    "electron-builder": "^26.7.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.0"
  }
}
