generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────────

enum ChannelType {
  TEXT
  VOICE
  DM
  GROUP_DM
}

enum FriendStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

// ─── User ───────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String?  @unique
  username      String   @unique
  discriminator String   @db.VarChar(4)
  password      String
  avatar        String?
  banner        String?
  about         String?
  status        String   @default("online")
  customStatus  String?
  isAnonymous   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ownedServers    Server[]         @relation("ServerOwner")
  serverMembers   ServerMember[]
  messages        Message[]
  reactions       Reaction[]
  friends         Friend[]         @relation("UserFriends")
  friendOf        Friend[]         @relation("FriendOfUser")
  channelMembers  ChannelMember[]
  createdInvites  Invite[]
  createdEmojis   CustomEmoji[]
  serverBans      ServerBan[]      @relation("BannedUser")
  executedBans    ServerBan[]      @relation("BannedByUser")

  @@index([email])
  @@index([username])
  @@index([status])
}

// ─── Server ─────────────────────────────────────────────────────────────────────

model Server {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  icon        String?
  banner      String?
  ownerId     String   @db.Uuid
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner    User           @relation("ServerOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members  ServerMember[]
  channels Channel[]
  roles    Role[]
  invites  Invite[]
  emojis   CustomEmoji[]
  bans     ServerBan[]

  @@index([ownerId])
  @@index([isPublic])
  @@index([name])
}

// ─── ServerMember ───────────────────────────────────────────────────────────────

model ServerMember {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @db.Uuid
  serverId String   @db.Uuid
  nickname String?
  joinedAt DateTime @default(now())

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  server Server           @relation(fields: [serverId], references: [id], onDelete: Cascade)
  roles  ServerMemberRole[]

  @@unique([userId, serverId])
  @@index([userId])
  @@index([serverId])
}

// ─── Channel ────────────────────────────────────────────────────────────────────

model Channel {
  id        String      @id @default(uuid()) @db.Uuid
  name      String
  topic     String?
  type      ChannelType @default(TEXT)
  serverId  String?     @db.Uuid
  position  Int         @default(0)
  slowmode  Int         @default(0)
  isPrivate Boolean     @default(false)
  createdAt DateTime    @default(now())

  server      Server?          @relation(fields: [serverId], references: [id], onDelete: Cascade)
  messages    Message[]
  permissions ChannelPermission[]
  members     ChannelMember[]

  @@index([serverId])
  @@index([type])
  @@index([serverId, position])
}

// ─── ChannelMember (for DM / GROUP_DM channels) ─────────────────────────────────

model ChannelMember {
  id        String   @id @default(uuid()) @db.Uuid
  channelId String   @db.Uuid
  userId    String   @db.Uuid
  joinedAt  DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
  @@index([channelId])
}

// ─── Message ────────────────────────────────────────────────────────────────────

model Message {
  id           String    @id @default(uuid()) @db.Uuid
  content      String
  authorId     String    @db.Uuid
  channelId    String    @db.Uuid
  replyToId    String?   @db.Uuid
  attachments  Json      @default("[]")
  embeds       Json      @default("[]")
  pinned       Boolean   @default(false)
  edited       Boolean   @default(false)
  selfDestruct DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  channel   Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  replyTo   Message?   @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[]  @relation("MessageReplies")
  reactions Reaction[]

  @@index([channelId])
  @@index([authorId])
  @@index([channelId, createdAt])
  @@index([replyToId])
}

// ─── Role ───────────────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  color       String?
  serverId    String   @db.Uuid
  permissions BigInt   @default(0)
  position    Int      @default(0)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  server  Server             @relation(fields: [serverId], references: [id], onDelete: Cascade)
  members ServerMemberRole[]

  @@index([serverId])
  @@index([serverId, position])
}

// ─── ServerMemberRole (linking table) ───────────────────────────────────────────

model ServerMemberRole {
  id             String @id @default(uuid()) @db.Uuid
  serverMemberId String @db.Uuid
  roleId         String @db.Uuid

  serverMember ServerMember @relation(fields: [serverMemberId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([serverMemberId, roleId])
  @@index([serverMemberId])
  @@index([roleId])
}

// ─── Friend ─────────────────────────────────────────────────────────────────────

model Friend {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @db.Uuid
  friendId  String       @db.Uuid
  status    FriendStatus @default(PENDING)
  createdAt DateTime     @default(now())

  user   User @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendOfUser", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
  @@index([status])
}

// ─── Invite ─────────────────────────────────────────────────────────────────────

model Invite {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique
  serverId  String    @db.Uuid
  creatorId String    @db.Uuid
  maxUses   Int       @default(0)
  uses      Int       @default(0)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  server  Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  creator User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([serverId])
}

// ─── Reaction ───────────────────────────────────────────────────────────────────

model Reaction {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @db.Uuid
  userId    String   @db.Uuid
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
}

// ─── CustomEmoji ────────────────────────────────────────────────────────────────

model CustomEmoji {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  serverId  String   @db.Uuid
  imageUrl  String
  creatorId String   @db.Uuid
  createdAt DateTime @default(now())

  server  Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  creator User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@index([name])
}

// ─── ServerBan ──────────────────────────────────────────────────────────────────

model ServerBan {
  id         String   @id @default(uuid()) @db.Uuid
  serverId   String   @db.Uuid
  userId     String   @db.Uuid
  reason     String?
  bannedById String   @db.Uuid
  createdAt  DateTime @default(now())

  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user     User   @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  bannedBy User   @relation("BannedByUser", fields: [bannedById], references: [id], onDelete: Cascade)

  @@unique([serverId, userId])
  @@index([serverId])
  @@index([userId])
}

// ─── ChannelPermission ──────────────────────────────────────────────────────────

model ChannelPermission {
  id        String @id @default(uuid()) @db.Uuid
  channelId String @db.Uuid
  roleId    String @db.Uuid
  allow     BigInt @default(0)
  deny      BigInt @default(0)

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, roleId])
  @@index([channelId])
}
